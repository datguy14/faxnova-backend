# Sinch Fax API Credentials
SINCH_KEY_ID=your_sinch_key_id_here
SINCH_KEY_SECRET=your_sinch_key_secret_here
SINCH_PROJECT_ID=your_sinch_project_id_here

# Fax Settings
SINCH_FAX_NUMBER=+1XXXXXXXXXX

# FaxNova API Key (required in production — used to authenticate all API requests)
# Generate a strong random key: openssl rand -hex 32
FAXNOVA_API_KEY=your_api_key_here

# Webhook Security
FAX_WEBHOOK_SECRET=your_webhook_secret_here

# Server
PORT=5000
NODE_ENV=development
